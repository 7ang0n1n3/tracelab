FRONTEND_PORT=3273
BACKEND_PORT=4000
RUNNER_PORT=5000
NOVNC_PORT=6080

# Public browser URL for the TraceLab UI. Set this to your server IP/domain in Docker/Portainer.
# Example: FRONTEND_URL=http://10.0.1.115:3273
FRONTEND_URL=http://localhost:3273

# Shared secret between backend and runner.
# Set to a long random string in production (e.g. openssl rand -hex 32).
# If left empty the runner relies on Docker network isolation only.
RUNNER_SECRET=

# Set to "true" to mark the session cookie Secure (requires HTTPS).
HTTPS_ONLY=false
